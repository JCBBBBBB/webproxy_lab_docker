{
    "version": 4,
    "configurations": [
        {
            "name": "webproxy-lab",
            "includePath": [
                "${workspaceFolder}",
                "${workspaceFolder}/webproxy-lab",
                "${workspaceFolder}/webproxy-lab/tiny",
                "${workspaceFolder}/webproxy-lab/**"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}",
                    "${workspaceFolder}/webproxy-lab",
                    "${workspaceFolder}/webproxy-lab/tiny"
                ],
                "limitSymbolsToIncludedHeaders": true
            },
            "defines": [],
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-x64"
        }
    ]
}
